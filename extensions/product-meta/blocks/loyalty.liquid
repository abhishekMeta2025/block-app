{% comment %}
  Loyalty block: reads percentage from shop metafield (set in app admin)
  and shows points the customer can earn based on product price.
{% endcomment %}

{% assign points_percentage = shop.metafields.loyalty.points_percentage.value %}

{% if points_percentage != blank and points_percentage != 0 and product %}
  {% assign price_dollars = product.price | divided_by: 100.0 %}
  {% assign points = price_dollars | times: points_percentage | divided_by: 100.0 %}

  <div class="loyalty-points" style="margin: 12px 0; padding: 10px 14px; background: #f5f5f5; border-left: 4px solid #008060; border-radius: 4px; font-size: 14px;">
    🎁 Earn <strong>{{ points | round }}</strong> loyalty points on this purchase.
  </div>
{% endif %}

{% schema %}
{
  "name": "Loyalty Points",
  "target": "section",
  "settings": []
}
{% endschema %}